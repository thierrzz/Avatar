# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# JWKS URL is derived from SUPABASE_URL; the secret below is used for HS256
# tokens when verifying JWTs issued by the project. Copy it from Supabase
# dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PRICE_ID_STARTER=price_...
PRICE_ID_PLUS=price_...
PRICE_ID_STUDIO=price_...

# --- Replicate ---
REPLICATE_API_TOKEN=r8_...

# --- App ---
# Used in Stripe Checkout return URLs. Matches the CFBundleURLTypes entry in
# the macOS app's Info.plist.
APP_URL_SCHEME=aaavatar
# Public marketing site (for legal / pricing pages linked from Checkout).
PUBLIC_SITE_URL=https://aaavatar.nl
